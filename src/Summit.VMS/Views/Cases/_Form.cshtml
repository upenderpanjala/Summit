@model CaseFormViewModel

<div class="row g-3">
    <div class="col-md-4">
        <label asp-for="CaseNumber" class="form-label"></label>
        <input asp-for="CaseNumber" class="form-control" />
        <span asp-validation-for="CaseNumber" class="text-danger small"></span>
    </div>
    <div class="col-md-8">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="Type" class="form-label"></label>
        <select asp-for="Type" asp-items="Html.GetEnumSelectList<CaseType>()" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" asp-items="Html.GetEnumSelectList<CaseStatus>()" class="form-select"></select>
    </div>
    <div class="col-md-4">
        <label asp-for="Location" class="form-label"></label>
        <input asp-for="Location" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="PoliceStationId" class="form-label"></label>
        <select asp-for="PoliceStationId" asp-items="ViewBag.Stations" class="form-select">
            <option value="">— none —</option>
        </select>
    </div>
    <div class="col-md-6">
        <label asp-for="AssignedOfficerId" class="form-label"></label>
        <select asp-for="AssignedOfficerId" asp-items="ViewBag.Officers" class="form-select">
            <option value="">— unassigned —</option>
        </select>
    </div>
    <div class="col-12">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
    </div>
</div>
