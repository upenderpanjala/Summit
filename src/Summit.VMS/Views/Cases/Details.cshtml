@model CaseRecord
@{
    ViewData["Title"] = Model.CaseNumber;
    var canManage = User.IsInRole(AppRoles.Administrator) || User.IsInRole(AppRoles.Investigator);
    var canViewVictims = !User.IsInRole(AppRoles.HomeMinister);
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><span class="badge text-bg-dark me-2">@Model.CaseNumber</span>@Model.Title</h1>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        @if (canManage)
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="bi bi-pencil me-1"></i>Edit</a>
        }
    </div>
</div>

<div class="card p-4 mb-3">
    <dl class="row mb-0">
        <dt class="col-sm-3">Type</dt><dd class="col-sm-9">@Model.Type</dd>
        <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
        <dt class="col-sm-3">Location</dt><dd class="col-sm-9">@(Model.Location ?? "—")</dd>
        <dt class="col-sm-3">Station</dt><dd class="col-sm-9">@(Model.PoliceStation?.Name ?? "—")</dd>
        <dt class="col-sm-3">Assigned officer</dt><dd class="col-sm-9">@(Model.AssignedOfficer?.FullName ?? "—")</dd>
        <dt class="col-sm-3">Reported</dt><dd class="col-sm-9">@Model.DateReportedUtc.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-3">Description</dt><dd class="col-sm-9" style="white-space:pre-wrap">@(Model.Description ?? "—")</dd>
    </dl>
</div>

@if (canViewVictims)
{
    <div class="card p-4">
        <h2 class="h5">Linked victims (@Model.Victims.Count)</h2>
        <ul class="list-group list-group-flush">
            @foreach (var v in Model.Victims)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span><span class="badge text-bg-secondary me-2">@v.ReferenceNumber</span>@v.FullName</span>
                    <a asp-controller="Victims" asp-action="Details" asp-route-id="@v.Id">View</a>
                </li>
            }
            @if (!Model.Victims.Any())
            {
                <li class="list-group-item text-muted">No victims linked.</li>
            }
        </ul>
    </div>
}
