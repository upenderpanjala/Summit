@model IReadOnlyList<CaseRecord>
@{
    ViewData["Title"] = "Cases";
    var canManage = User.IsInRole(AppRoles.Administrator) || User.IsInRole(AppRoles.Investigator);
    var search = ViewData["Search"] as string;
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Cases</h1>
    @if (canManage)
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New case</a>
    }
</div>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width:420px">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Search case number or title…" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
    </div>
</form>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr><th>Case #</th><th>Title</th><th>Type</th><th>Status</th><th>Victims</th><th>Reported</th><th></th></tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No cases found.</td></tr>
            }
            @foreach (var c in Model)
            {
                <tr>
                    <td><span class="badge text-bg-dark">@c.CaseNumber</span></td>
                    <td>@c.Title</td>
                    <td>@c.Type</td>
                    <td><span class="badge text-bg-info">@c.Status</span></td>
                    <td>@c.Victims.Count</td>
                    <td>@c.DateReportedUtc.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@c.Id">View</a>
                        @if (canManage)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.Id"><i class="bi bi-pencil"></i></a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
