@{
    ViewData["Title"] = "Dashboard";
    var isViewOnly = User.IsInRole(AppRoles.PoliceHierarchy) || User.IsInRole(AppRoles.HomeMinister);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Dashboard</h1>
</div>

@if (isViewOnly)
{
    <div class="alert alert-info">
        <i class="bi bi-eye me-1"></i>
        Your role has <strong>view-only</strong> access to victim details. Editing is disabled.
    </div>
}

<div class="row g-3">
    <div class="col-sm-6 col-lg-4">
        <div class="card stat-card p-4">
            <div class="text-muted small text-uppercase">Victims</div>
            <div class="display-6 fw-bold">@ViewBag.VictimCount</div>
            <a asp-controller="Victims" asp-action="Index" class="stretched-link"></a>
        </div>
    </div>
    @if (!User.IsInRole(AppRoles.HomeMinister))
    {
        <div class="col-sm-6 col-lg-4">
            <div class="card stat-card p-4">
                <div class="text-muted small text-uppercase">Cases</div>
                <div class="display-6 fw-bold">@ViewBag.CaseCount</div>
                <a asp-controller="Cases" asp-action="Index" class="stretched-link"></a>
            </div>
        </div>
    }
</div>

<div class="card mt-4 p-4">
    <h2 class="h5">Quick actions</h2>
    <div class="d-flex flex-wrap gap-2 mt-2">
        <a class="btn btn-outline-primary" asp-controller="Victims" asp-action="Index">
            <i class="bi bi-people me-1"></i>Browse victims
        </a>
        @if (User.IsInRole(AppRoles.Administrator) || User.IsInRole(AppRoles.Investigator))
        {
            <a class="btn btn-primary" asp-controller="Victims" asp-action="Create">
                <i class="bi bi-plus-lg me-1"></i>New victim record
            </a>
        }
    </div>
</div>
