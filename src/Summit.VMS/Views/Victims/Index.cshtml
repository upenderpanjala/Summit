@model IReadOnlyList<Victim>
@{
    ViewData["Title"] = "Victims";
    var canManage = User.IsInRole(AppRoles.Administrator) || User.IsInRole(AppRoles.Investigator);
    var search = ViewData["Search"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Victim records</h1>
    @if (canManage)
    {
        <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i>New victim</a>
    }
</div>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width:420px">
        <input type="text" name="search" value="@search" class="form-control"
               placeholder="Search reference, name, city…" />
        <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
    </div>
</form>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
            <tr>
                <th>Reference</th><th>Name</th><th>Gender</th><th>City</th>
                <th>Case</th><th class="text-end">Actions</th>
            </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-center text-muted py-4">No records found.</td></tr>
            }
            @foreach (var v in Model)
            {
                <tr>
                    <td><span class="badge text-bg-secondary">@v.ReferenceNumber</span></td>
                    <td>@v.FullName</td>
                    <td>@v.Gender</td>
                    <td>@v.City</td>
                    <td>@(v.Case?.CaseNumber ?? "—")</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@v.Id">
                            <i class="bi bi-eye"></i> View
                        </a>
                        @if (canManage)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@v.Id">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@v.Id">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
