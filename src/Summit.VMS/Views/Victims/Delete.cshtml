@model Victim
@{
    ViewData["Title"] = "Delete victim";
}
<h1 class="h3 mb-3 text-danger">Delete victim record</h1>
<div class="card p-4">
    <p>Are you sure you want to permanently delete this record?</p>
    <dl class="row">
        <dt class="col-sm-3">Reference</dt><dd class="col-sm-9">@Model.ReferenceNumber</dd>
        <dt class="col-sm-3">Name</dt><dd class="col-sm-9">@Model.FullName</dd>
    </dl>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
    </form>
</div>
