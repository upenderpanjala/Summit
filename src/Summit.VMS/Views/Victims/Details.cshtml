@model Victim
@{
    ViewData["Title"] = $"Victim {Model.ReferenceNumber}";
    var canManage = User.IsInRole(AppRoles.Administrator) || User.IsInRole(AppRoles.Investigator);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">
        <span class="badge text-bg-secondary me-2">@Model.ReferenceNumber</span>@Model.FullName
    </h1>
    <div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        @if (canManage)
        {
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
    </div>
</div>

<div class="card p-4">
    <dl class="row mb-0">
        <dt class="col-sm-3">Reference number</dt><dd class="col-sm-9">@Model.ReferenceNumber</dd>
        <dt class="col-sm-3">Full name</dt><dd class="col-sm-9">@Model.FullName</dd>
        <dt class="col-sm-3">Gender</dt><dd class="col-sm-9">@Model.Gender</dd>
        <dt class="col-sm-3">Date of birth</dt><dd class="col-sm-9">@(Model.DateOfBirth?.ToString("yyyy-MM-dd") ?? "—")</dd>
        <dt class="col-sm-3">National ID</dt><dd class="col-sm-9">@(Model.NationalId ?? "—")</dd>
        <dt class="col-sm-3">Contact number</dt><dd class="col-sm-9">@(Model.ContactNumber ?? "—")</dd>
        <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@(Model.Email ?? "—")</dd>
        <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@(Model.Address ?? "—")</dd>
        <dt class="col-sm-3">City / State</dt><dd class="col-sm-9">@Model.City @(string.IsNullOrEmpty(Model.State) ? "" : ", " + Model.State)</dd>
        <dt class="col-sm-3">Linked case</dt>
        <dd class="col-sm-9">
            @if (Model.Case != null)
            {
                <a asp-controller="Cases" asp-action="Details" asp-route-id="@Model.Case.Id">@Model.Case.CaseNumber — @Model.Case.Title</a>
            }
            else { <text>—</text> }
        </dd>
        <dt class="col-sm-3">Notes / statement</dt>
        <dd class="col-sm-9" style="white-space:pre-wrap">@(Model.Notes ?? "—")</dd>
    </dl>
</div>
<p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>This view is recorded in the audit log.</p>

@{
    var documents = Model.Documents;
}

<div class="card p-4 mt-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0"><i class="bi bi-paperclip me-1"></i>Documents (@documents.Count)</h2>
    </div>

    @if (canManage)
    {
        <form asp-controller="Documents" asp-action="Upload" method="post"
              enctype="multipart/form-data" class="row g-2 align-items-center mb-3">
            <input type="hidden" name="victimId" value="@Model.Id" />
            <div class="col-sm-8 col-md-6">
                <input type="file" name="file" class="form-control" required
                       accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.txt,.xlsx,.csv" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-accent">
                    <i class="bi bi-upload me-1"></i>Upload
                </button>
            </div>
            <div class="col-12">
                <small class="text-muted">Allowed: pdf, doc(x), xlsx, csv, txt, jpg, png — up to 10 MB.</small>
            </div>
        </form>
    }

    @if (!documents.Any())
    {
        <p class="text-muted mb-0">No documents attached.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
                <thead>
                <tr><th>File</th><th>Size</th><th>Uploaded by</th><th>When</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody>
                @foreach (var d in documents.OrderByDescending(x => x.UploadedAtUtc))
                {
                    <tr>
                        <td><i class="bi bi-file-earmark-text me-1"></i>@d.FileName</td>
                        <td>@($"{d.SizeBytes / 1024.0:0.#} KB")</td>
                        <td>@(d.UploadedByName ?? "—")</td>
                        <td>@d.UploadedAtUtc.ToLocalTime().ToString("g")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               asp-controller="Documents" asp-action="Download" asp-route-id="@d.Id">
                                <i class="bi bi-download"></i>
                            </a>
                            @if (canManage)
                            {
                                <form asp-controller="Documents" asp-action="Delete" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <input type="hidden" name="victimId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Delete this document?');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
